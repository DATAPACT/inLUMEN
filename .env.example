# OpenAI-compatible LLM provider used by the backend agent.
# The browser never talks to this provider directly.
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=gpt-oss-120b

# Local ports. Change these only when the defaults conflict with your machine.
# Only FRONTEND_PORT, INLUMEN_API_PORT, NEO4J_HTTP_PORT, NEO4J_BOLT_PORT,
# MINIO_S3_PORT, and MINIO_CONSOLE_PORT are exposed to the host by Compose.
FRONTEND_PORT=8080
INLUMEN_API_PORT=5000

# Internal backend adapter ports. These are implementation details inside the backend container.
MINIO_API_PORT=5003
NEO4J_API_PORT=5001

# Database/admin console ports exposed for local development.
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
MINIO_S3_PORT=9000
MINIO_CONSOLE_PORT=9099

# Local development credentials.
NEO4J_AUTH=neo4j/password
MINIO_ROOT_USER=minio-datapact
MINIO_ROOT_PASSWORD=minio-datapact

# Public API authentication token used when AUTH_ENABLED=false.
API_AUTH_TOKEN=change-me-local-token

# Authentication is off by default. If you set AUTH_ENABLED=true, fill in the
# Keycloak values below; Docker Compose mirrors this switch to the frontend.
AUTH_ENABLED=false
KEYCLOAK_JWKS_URL=
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=inlumen
VITE_KEYCLOAK_CLIENT_ID=inlumen-frontend
VITE_ENABLE_REMOTE_CHATBOT_CONFIG_SYNC=true

# Backend development file watcher.
WATCH_INTERVAL_SECONDS=1.0
