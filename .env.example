OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OLLAMA_MODEL=llama3.1:8b
DEFAULT_CHAT_MODEL=llama3.1

# Local ports. Change these only when the defaults conflict with your machine.
FRONTEND_PORT=8080
MINIO_API_PORT=5003
NEO4J_API_PORT=5001
LLM_API_PORT=5002
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
MINIO_S3_PORT=9000
MINIO_CONSOLE_PORT=9099
OLLAMA_PORT=11434

# Local development credentials.
NEO4J_AUTH=neo4j/password
MINIO_ROOT_USER=minio-datapact
MINIO_ROOT_PASSWORD=minio-datapact

# Authentication is off by default. If you set AUTH_ENABLED=true, fill in the
# Keycloak values below; Docker Compose mirrors this switch to the frontend.
AUTH_ENABLED=false
KEYCLOAK_JWKS_URL=
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=
WATCH_INTERVAL_SECONDS=1.0
